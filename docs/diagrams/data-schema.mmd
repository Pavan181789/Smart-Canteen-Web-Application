erDiagram
  users {
    string uid PK
    string displayName
    string email
    string photoURL
    timestamp creationTime
    number wallet
  }

  menu {
    string id PK
    string itemName
    number cost
    string thumbnail
    string category
    string veg
  }

  orders {
    string id PK
    string uid FK
    json orders
    timestamp createdAt
    number total
    string status
  }

  ai_chats {
    string id PK
    string userId FK
    string question
    string response
    timestamp timestamp
  }

  users ||--o{ orders : places
  users ||--o{ ai_chats : chats
